<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WordWhiz.Views.OptimizationPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:WordWhiz.ViewModels"
    xmlns:models="using:WordWhiz.Models">

    <Border Background="{StaticResource BgSecondaryBrush}"
            CornerRadius="12"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Width="660" Height="660">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>  <!-- Header -->
                <RowDefinition Height="45"/>  <!-- Mode Selector -->
                <RowDefinition Height="Auto"/>  <!-- Source Section -->
                <RowDefinition Height="*"/>     <!-- Result Section -->
                <RowDefinition Height="50"/>  <!-- Action Bar -->
            </Grid.RowDefinitions>

            <!-- Panel Header -->
            <Grid Grid.Row="0" Padding="16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Border Background="{StaticResource AccentBrush}" CornerRadius="4" Width="28" Height="28">
                        <TextBlock Text="Ww" Foreground="White" FontWeight="Bold" FontSize="12"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="WordWhiz" Foreground="{StaticResource TextPrimaryBrush}"
                               FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button Content="⚙" FontSize="14" Background="Transparent"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Click="SettingsButton_Click" Padding="8"/>
                    <Button x:Name="PinButton" Content="📌" FontSize="14" Background="Transparent"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Click="PinButton_Click" Padding="8"/>
                </StackPanel>
            </Grid>

            <!-- Mode Selector (Prompt Tabs) -->
            <ScrollViewer Grid.Row="1" HorizontalScrollMode="Enabled" HorizontalScrollBarVisibility="Auto"
                          VerticalScrollMode="Disabled" Padding="16,0">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Prompts, Mode=OneWay}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:CustomPrompt">
                                <Button Content="{x:Bind Name}" Padding="12,6"
                                        CornerRadius="6" FontSize="12"
                                        Click="PromptTab_Click" Tag="{x:Bind}"/>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="4"/>
                        </ItemsRepeater.Layout>
                    </ItemsRepeater>
                </StackPanel>
            </ScrollViewer>

            <!-- Source Section (Collapsible) -->
            <Border Grid.Row="2" Padding="16,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="原文" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Padding="4" Background="Transparent"
                                Foreground="{StaticResource TextMutedBrush}"
                                Click="ToggleSource_Click" FontSize="10">
                            <TextBlock x:Name="CollapseIcon" Text="▼"/>
                        </Button>
                    </Grid>

                    <Border x:Name="SourceContent" Grid.Row="1" Margin="0,4,0,0"
                            Background="{StaticResource BgTertiaryBrush}" CornerRadius="6" Padding="8"
                            MaxHeight="80">
                        <TextBlock Text="{x:Bind ViewModel.SourceText, Mode=OneWay}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                   MaxLines="3"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Result Section -->
            <Grid Grid.Row="3" Padding="16,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Status Bar -->
                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="优化结果" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <TextBlock x:Name="StatusText" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center">
                            <Run Text="{x:Bind ViewModel.ResultCharacterCount, Mode=OneWay}"/>
                            <Run Text="字"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- Result TextBox -->
                <TextBox x:Name="ResultEditor" Grid.Row="1"
                         Text="{x:Bind ViewModel.ResultText, Mode=OneWay}"
                         IsReadOnly="{x:Bind ViewModel.IsStreaming, Mode=OneWay}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Background="{StaticResource BgTertiaryBrush}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderBrush="{StaticResource BorderBrush}"
                         CornerRadius="8" Padding="12" FontSize="13"
                         TextChanged="ResultEditor_TextChanged"/>

                <!-- Stop Button (shown during streaming) -->
                <Button x:Name="StopButton" Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,8,8,0" Padding="8,4" CornerRadius="6"
                        Background="#FF3B30" Foreground="White" FontSize="11"
                        Content="■ 停止" Visibility="Collapsed"
                        Click="StopButton_Click"/>
            </Grid>

            <!-- Action Bar -->
            <Border Grid.Row="4" Padding="16,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="🔄 重新生成" Padding="12,6" CornerRadius="6"
                            Background="{StaticResource BgTertiaryBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"
                            Click="Regenerate_Click"/>

                    <Button Grid.Column="2" Content="全选" Padding="12,6" CornerRadius="6"
                            Background="{StaticResource BgTertiaryBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,8,0"
                            Click="SelectAll_Click"/>

                    <Button x:Name="CopyButton" Grid.Column="3" Padding="16,6" CornerRadius="6"
                            Background="{StaticResource AccentBrush}" Foreground="White" FontSize="12"
                            Content="📋 复制结果" Click="Copy_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Page>

<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="WordWhiz.Views.Pages.HotkeyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="16" MaxWidth="500" HorizontalAlignment="Left">
            <TextBlock Text="快捷键设置" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>

            <Border Background="{StaticResource BgTertiaryBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="16">
                    <!-- Trigger Hotkey -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="触发优化" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="全局快捷键，在任意应用中按下即可唤出优化面板"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" Width="160"
                                  ItemsSource="{x:Bind VM.HotkeyPresets}"
                                  DisplayMemberPath="DisplayString"
                                  SelectedIndex="0"/>
                    </Grid>

                    <Border Height="1" Background="{StaticResource BorderBrush}"/>

                    <!-- Other hotkeys (read-only display) -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="复制结果" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="Ctrl+Shift+C"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Consolas" VerticalAlignment="Center"/>
                    </Grid>

                    <Border Height="1" Background="{StaticResource BorderBrush}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="重新生成" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="Ctrl+R"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Consolas" VerticalAlignment="Center"/>
                    </Grid>

                    <Border Height="1" Background="{StaticResource BorderBrush}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="切换指令" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="Ctrl+1 ~ Ctrl+9"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Consolas" VerticalAlignment="Center"/>
                    </Grid>

                    <Border Height="1" Background="{StaticResource BorderBrush}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="关闭面板" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="Esc"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Consolas" VerticalAlignment="Center"/>
                    </Grid>

                    <Border Height="1" Background="{StaticResource BorderBrush}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="打开设置" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="Ctrl+Shift+,"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Consolas" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="注：触发优化和打开设置为全局快捷键，其他快捷键仅在面板激活时有效。"
                       Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</Page>

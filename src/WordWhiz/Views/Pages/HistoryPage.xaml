<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="WordWhiz.Views.Pages.HistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="using:WordWhiz.Models">
    <Grid RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="历史记录" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <Button Grid.Column="1" Content="清空全部" Foreground="{StaticResource ErrorBrush}"
                    Background="Transparent" Click="ClearAll_Click" CornerRadius="6" Padding="12,6"/>
        </Grid>

        <AutoSuggestBox Grid.Row="1" PlaceholderText="搜索历史记录..."
                         QuerySubmitted="Search_Submitted"
                         Background="{StaticResource BgTertiaryBrush}"/>

        <ListView Grid.Row="2" ItemsSource="{x:Bind VM.HistoryRecords, Mode=OneWay}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:OptimizationRecord">
                    <Border Background="{StaticResource BgTertiaryBrush}" CornerRadius="6" Padding="12" Margin="0,2">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Background="{StaticResource AccentBrush}" CornerRadius="4" Padding="6,2"
                                            Visibility="{x:Bind PromptName, Converter={StaticResource NullToVisibilityConverter}, FallbackValue=Collapsed}">
                                        <TextBlock Text="{x:Bind PromptName}" FontSize="10" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="{x:Bind CreatedAt, Converter={StaticResource DateTimeConverter}, FallbackValue=''}"
                                               FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                </StackPanel>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"
                                           MaxLines="2" TextTrimming="CharacterEllipsis">
                                    <Run Text="原文: "/><Run Text="{x:Bind SourceText}"/>
                                </TextBlock>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           MaxLines="2" TextTrimming="CharacterEllipsis">
                                    <Run Text="结果: "/><Run Text="{x:Bind ResultText}"/>
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1" Content="🗑" FontSize="12"
                                    Background="Transparent" Padding="4" VerticalAlignment="Top"
                                    Click="DeleteRecord_Click" Tag="{x:Bind}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

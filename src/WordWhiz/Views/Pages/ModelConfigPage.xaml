<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="WordWhiz.Views.Pages.ModelConfigPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="using:WordWhiz.Models">
    <ScrollViewer>
        <StackPanel Spacing="16" MaxWidth="500" HorizontalAlignment="Left">
            <TextBlock Text="模型配置" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>

            <Border Background="{StaticResource BgTertiaryBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="LLM 服务商" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                        <ComboBox x:Name="ProviderCombo" Width="300" HorizontalAlignment="Left"
                                  SelectionChanged="Provider_Changed">
                            <ComboBoxItem Content="OpenAI (GPT-4o)" Tag="OpenAI"/>
                            <ComboBoxItem Content="Anthropic (Claude)" Tag="Anthropic"/>
                            <ComboBoxItem Content="DeepSeek" Tag="DeepSeek"/>
                            <ComboBoxItem Content="通义千问" Tag="Qwen"/>
                            <ComboBoxItem Content="Google Gemini" Tag="Gemini"/>
                            <ComboBoxItem Content="Kimi (Moonshot)" Tag="Kimi"/>
                            <ComboBoxItem Content="智谱 GLM" Tag="GLM"/>
                            <ComboBoxItem Content="MiniMax" Tag="MiniMax"/>
                            <ComboBoxItem Content="自定义 (OpenAI 兼容)" Tag="Custom"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="API Key" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                        <PasswordBox x:Name="ApiKeyBox" Width="300" HorizontalAlignment="Left"
                                     PlaceholderText="输入 API Key"
                                     PasswordChanged="ApiKey_Changed"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="API Base URL" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                        <TextBox x:Name="BaseUrlBox" Width="300" HorizontalAlignment="Left"
                                 PlaceholderText="https://api.example.com/v1"
                                 Text="{x:Bind VM.BaseUrl, Mode=TwoWay}"
                                 LostFocus="ApiSetting_Changed"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="模型名称" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                        <TextBox x:Name="ModelBox" Width="300" HorizontalAlignment="Left"
                                 PlaceholderText="gpt-4o"
                                 Text="{x:Bind VM.ModelName, Mode=TwoWay}"
                                 LostFocus="ApiSetting_Changed"/>
                    </StackPanel>

                    <Button Content="测试连接" Click="TestConnection_Click"
                            Background="{StaticResource AccentBrush}" Foreground="White"
                            CornerRadius="6" Padding="16,8" IsEnabled="{x:Bind VM.IsTestingConnection, Mode=OneWay, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>

                    <TextBlock x:Name="TestResult" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>

<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="WordWhiz.Views.Pages.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="20" VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="{StaticResource AccentBrush}" CornerRadius="12" Width="64" Height="64"
                HorizontalAlignment="Center">
            <TextBlock Text="Ww" Foreground="White" FontWeight="Bold" FontSize="24"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <TextBlock Text="WordWhiz" FontSize="24" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>

        <TextBlock Text="版本 1.0.0" FontSize="14"
                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>

        <TextBlock Text="一款智能文案优化工具&#x0a;通过 AI 大语言模型帮你润色、翻译、改写文案"
                   Foreground="{StaticResource TextMutedBrush}" FontSize="13"
                   TextAlignment="Center" HorizontalAlignment="Center"/>

        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" Margin="0,16,0,0">
            <HyperlinkButton Content="GitHub" NavigateUri="https://github.com/dongritengfei/WordWhiz"
                             Foreground="{StaticResource AccentBrush}"/>
            <HyperlinkButton Content="反馈问题" NavigateUri="https://github.com/dongritengfei/WordWhiz/issues"
                             Foreground="{StaticResource AccentBrush}"/>
        </StackPanel>

        <TextBlock Text="MIT License | 100% AI Generated Code"
                   Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                   HorizontalAlignment="Center"/>
    </StackPanel>
</Page>

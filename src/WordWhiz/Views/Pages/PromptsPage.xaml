<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="WordWhiz.Views.Pages.PromptsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="using:WordWhiz.Models">
    <Grid RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="指令管理" FontSize="20" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"/>

        <!-- Prompt list -->
        <ListView Grid.Row="1" ItemsSource="{x:Bind VM.Prompts, Mode=OneWay}"
                  SelectionMode="Single"
                  SelectedItem="{x:Bind VM.SelectedPromptItem, Mode=TwoWay}"
                  SelectionChanged="Prompt_Selected">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:CustomPrompt">
                    <Grid Padding="8" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="{x:Bind Preview}" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       MaxLines="2" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="🗑" FontSize="12"
                                Background="Transparent" Padding="4"
                                Click="DeletePrompt_Click" Tag="{x:Bind}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Edit panel -->
        <Border Grid.Row="2" Background="{StaticResource BgTertiaryBrush}" CornerRadius="8" Padding="16"
                x:Name="EditPanel" Visibility="Collapsed">
            <StackPanel Spacing="8">
                <StackPanel Spacing="4">
                    <TextBlock Text="指令名称" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <TextBox x:Name="NameBox" LostFocus="SavePrompt_Click"/>
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="Prompt 模板 (使用 {{text}} 作为原文占位符)"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <TextBox x:Name="TemplateBox" AcceptsReturn="True" TextWrapping="Wrap"
                             Height="120" LostFocus="SavePrompt_Click"/>
                </StackPanel>
                <Button Content="保存" Click="SavePrompt_Click"
                        Background="{StaticResource AccentBrush}" Foreground="White"
                        CornerRadius="6" Padding="16,6"/>
            </StackPanel>
        </Border>

        <!-- Add button -->
        <Button Grid.Row="2" HorizontalAlignment="Stretch" Content="+ 添加新指令"
                Background="Transparent" Foreground="{StaticResource AccentBrush}"
                BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                CornerRadius="8" Padding="16,12" Click="AddPrompt_Click"
                x:Name="AddButton"/>
    </Grid>
</Page>

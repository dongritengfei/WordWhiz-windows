<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="WordWhiz.Views.Pages.GeneralPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="16" MaxWidth="500" HorizontalAlignment="Left">
            <TextBlock Text="通用设置" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>

            <Border Background="{StaticResource BgTertiaryBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="开机自启动" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="随 Windows 启动自动运行 WordWhiz"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind VM.LaunchAtStartup, Mode=TwoWay}"
                                      Toggled="Setting_Changed"/>
                    </Grid>

                    <Border Height="1" Background="{StaticResource BorderBrush}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="优化后自动复制" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="生成完成后自动复制结果到剪贴板"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind VM.AutoCopy, Mode=TwoWay}"
                                      Toggled="Setting_Changed"/>
                    </Grid>

                    <Border Height="1" Background="{StaticResource BorderBrush}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="保留优化历史" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="自动保存每次优化的记录"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind VM.KeepHistory, Mode=TwoWay}"
                                      Toggled="Setting_Changed"/>
                    </Grid>

                    <Border Height="1" Background="{StaticResource BorderBrush}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="面板弹出位置" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="优化面板在屏幕上的默认位置"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" SelectedIndex="{x:Bind PanelPositionIndex, Mode=TwoWay}"
                                  SelectionChanged="PanelPosition_Changed" Width="120">
                            <ComboBoxItem Content="屏幕右侧"/>
                            <ComboBoxItem Content="屏幕左侧"/>
                            <ComboBoxItem Content="屏幕中央"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
